{
  "uid": "crunch-spark",
  "title": "crunch — Spark & conteneurs",
  "tags": ["crunch", "spark"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Workers vivants",
      "description": "Nombre de workers Spark répondant au scrape Prometheus (up == 1).",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(up{job=\"spark-workers\"})",
          "legendFormat": "workers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Applications en cours (master)",
      "description": "Gauge du master Spark : applications actuellement enregistrées.",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "metrics_master_apps_Value{job=\"spark-master\"}",
          "legendFormat": "apps"
        },
        {
          "refId": "B",
          "expr": "metrics_master_waitingApps_Value{job=\"spark-master\"}",
          "legendFormat": "en attente"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU par conteneur (cœurs utilisés)",
      "description": "rate() sur le compteur cumulé de secondes CPU : 1.0 = un cœur saturé.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"spark-.*\"}[1m]))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["max", "mean"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Mémoire par conteneur (working set)",
      "description": "Gauge : mémoire réellement utilisée par conteneur, affichée telle quelle.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "container_memory_working_set_bytes{name=~\"spark-.*\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Réseau des workers (shuffle)",
      "description": "Débit réseau par worker : rx en positif, tx en négatif. Les pics correspondent aux shuffles.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (name) (rate(container_network_receive_bytes_total{name=~\"spark-worker.*\"}[1m]))",
          "legendFormat": "{{name}} rx"
        },
        {
          "refId": "B",
          "expr": "-sum by (name) (rate(container_network_transmit_bytes_total{name=~\"spark-worker.*\"}[1m]))",
          "legendFormat": "{{name}} tx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] },
        "tooltip": { "mode": "multi" }
      }
    }
  ]
}
